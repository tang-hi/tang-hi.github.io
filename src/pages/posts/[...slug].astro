---
import Post from '~/components/Post.astro'
import Toc from '~/components/Toc.astro'
import LayoutDefault from '~/layouts/LayoutDefault.astro'
import MusicPlayer from '~/components/MusicPlayer.astro'
import { getAllPosts, getLang, getTranslation } from '~/utils'
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro'
import Pagination from '~/components/Pagination.astro'

export const getStaticPaths = (async ({}) => {
  const posts = await getAllPosts()
  return posts.map((post) => {
    // Prev/next navigation moves within the same language; the other-language
    // variant is reached through the in-page toggle, not the prev/next chain.
    const chain = posts.filter((p) => getLang(p) === getLang(post))
    const idx = chain.findIndex((p) => p.slug === post.slug)
    const prev = chain[idx - 1]
    const next = chain[idx + 1]
    const translation = getTranslation(post, posts)
    return {
      params: { slug: post.slug },
      props: { entry: post, next, prev, translation },
    }
  })
}) satisfies GetStaticPaths

type Props = InferGetStaticPropsType<typeof getStaticPaths>

const { entry, prev, next, translation } = Astro.props
const { Content, headings } = await entry.render()
const { translate: t } = Astro.locals
const music = entry.data.music

// SEO/GEO: html lang follows the post's content language; bilingual pairs cross-link via hreflang.
const site = Astro.locals.config.website
const htmlLang = getLang(entry) === 'en' ? 'en' : 'zh-CN'
const postUrl = (p: Post) => new URL(`/posts/${p.slug}/`, site).toString()
let alternates: { hreflang: string; href: string }[] | undefined
if (translation) {
  const zh = getLang(entry) === 'zh' ? entry : translation
  const en = getLang(entry) === 'en' ? entry : translation
  alternates = [
    { hreflang: 'zh-CN', href: postUrl(zh) },
    { hreflang: 'en', href: postUrl(en) },
    { hreflang: 'x-default', href: postUrl(zh) },
  ]
}
---

<LayoutDefault
  title={entry.data.title}
  desc={entry.data.description}
  banner={entry.data.banner}
  lang={htmlLang}
  article={{ pubDate: entry.data.pubDate, categories: entry.data.categories }}
  alternates={alternates}
>
  <div class="post-shell">
    <Toc headings={headings} />
    <div class="post-body">
      <Post post={entry} translation={translation}>
        <Content />
      </Post>
      <Pagination
        showLeft={Boolean(prev)}
        leftTitle={`${t('prev_post')}: ${prev?.data.title}`}
        leftUrl={`/posts/${prev?.slug}/`}
        showRight={Boolean(next)}
        rightTitle={`${t('next_post')}: ${next?.data.title}`}
        rightUrl={`/posts/${next?.slug}/`}
        showPageCount={false}
      />
    </div>
  </div>
</LayoutDefault>

<script>
  import '@github/clipboard-copy-element'

  document.addEventListener('clipboard-copy', function (event) {
    const target = event.target as HTMLElement
    const icon = target.querySelector('.icon') as HTMLElement
    icon.classList.replace('i-mdi-content-copy', 'i-mdi-check')
    setTimeout(() => {
      icon.classList.replace('i-mdi-check', 'i-mdi-content-copy')
    }, 1500)
  })

  const codeBlocks = Array.from(document.querySelectorAll('pre'))
  const icon = "<div class='i-mdi-content-copy icon text-white'></div>"
  for (let codeBlock of codeBlocks) {
    let wrapper = document.createElement('div')
    wrapper.className = 'code-container'

    let copyButton = document.createElement('clipboard-copy')
    let code = codeBlock.querySelector('code')
    copyButton.value = code?.innerText ?? ''
    copyButton.className = 'clipboard-copy'
    copyButton.innerHTML = icon

    codeBlock.appendChild(copyButton)

    codeBlock.parentNode?.insertBefore(wrapper, codeBlock)
    wrapper.appendChild(codeBlock)
  }
</script>

<style is:global>
  /* article + left-rail table of contents.
     Below 1366px the TOC hides itself and the body keeps the full width. */
  .post-body {
    min-width: 0;
  }
  @media (min-width: 1366px) {
    /* widen the post container so the reading column keeps its full width
       (heti caps it at 42em) even with the TOC rail occupying the left side */
    body .container {
      max-width: 86rem;
    }
    .post-shell {
      display: flex;
      align-items: flex-start;
      gap: 2.5rem;
    }
    .post-body {
      flex: 1 1 auto;
    }
  }

  /* land a little below the top when jumping to a section */
  article.heti :is(h2, h3)[id] {
    scroll-margin-top: 5rem;
  }

  .code-container {
    position: relative;
  }
  .clipboard-copy {
    position: absolute;
    top: .5rem;
    right: .5rem;
    width: 1.75rem;
    height: 1.75rem;
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 0.25rem;
  }

  .clipboard-copy:hover {
    background-color: #30363d;
  }
</style>

{music && (
  <MusicPlayer
    url={music.url}
    title={music.title}
    artist={music.artist}
    cover={music.cover}
  />
)}
