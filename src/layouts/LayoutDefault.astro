---
import '~/styles/index.css'
// https://sivan.github.io/heti
import '~/styles/heti.min.css'
import Header from '~/components/Header.astro'
import Footer from '~/components/Footer.astro'
import { SEO } from 'astro-seo'
import { getImage } from 'astro:assets'

interface Props {
  title?: string
  desc?: string
  banner?: ImageMetadata
  /** content language of this page; defaults to zh-CN (the site is predominantly Chinese) */
  lang?: string
  /** present only on blog-post pages — drives og:type=article and the BlogPosting JSON-LD */
  article?: {
    pubDate: Date
    updatedDate?: Date
    categories: string[]
  }
  /** bilingual hreflang alternates (each version lists every version, incl. itself + x-default) */
  alternates?: { hreflang: string; href: string }[]
}

const props = Astro.props
const themeConfig = Astro.locals.config
const { header } = Astro.locals.config

const title = props.title ?? themeConfig.title
const desc = props.desc ?? themeConfig.desc
const lang = props.lang ?? 'zh-CN'
const { article, alternates } = props
const ogLocale = lang === 'en' ? 'en_US' : 'zh_CN'

const site = themeConfig.website
// self-referential canonical/og url for THIS page (astro-seo also defaults canonical to Astro.url)
const pageUrl = new URL(Astro.url.pathname, site).toString()

const image =
  props.banner &&
  (await getImage({
    src: props.banner,
    format: "jpeg"
  }))
// posts with a banner use it; everything else falls back to the branded default card
const optimizedImage = new URL(image?.src??"/og.png", Astro.url).toString()

// "%s" keeps the page's own title; sub-pages get the site name appended for branding,
// while the homepage (no own title) stays just "Don't Panic" rather than doubling up.
const titleTemplate = props.title && props.title !== themeConfig.title
  ? `%s · ${themeConfig.title}`
  : '%s'

// --- structured data (schema.org JSON-LD) — one @graph shared by every page ---
const personId = `${site}/#person`
const person = {
  '@type': 'Person',
  '@id': personId,
  name: themeConfig.author,
  url: site,
  // sameAs links the author entity to its profiles (helps engines/LLMs disambiguate "who")
  sameAs: themeConfig.socials.map((s) => s.href).filter((h) => h.startsWith('http')),
}
const websiteNode = {
  '@type': 'WebSite',
  '@id': `${site}/#website`,
  url: site,
  name: themeConfig.title,
  description: themeConfig.desc,
  inLanguage: lang,
  publisher: { '@id': personId },
}
const graph: Record<string, unknown>[] = [person, websiteNode]
if (article) {
  graph.push({
    '@type': 'BlogPosting',
    '@id': `${pageUrl}#article`,
    headline: title,
    description: desc,
    url: pageUrl,
    mainEntityOfPage: pageUrl,
    inLanguage: lang,
    datePublished: article.pubDate.toISOString(),
    dateModified: (article.updatedDate ?? article.pubDate).toISOString(),
    author: { '@id': personId },
    publisher: { '@id': personId },
    image: optimizedImage,
    ...(article.categories?.length
      ? { articleSection: article.categories, keywords: article.categories.join(', ') }
      : {}),
  })
  graph.push({
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: themeConfig.title, item: site },
      { '@type': 'ListItem', position: 2, name: title, item: pageUrl },
    ],
  })
}
// escape `<` so a stray `</script>` in any string can't break out of the tag
const jsonLd = JSON.stringify({ '@context': 'https://schema.org', '@graph': graph }).replace(/</g, '\\u003c')
---

<html lang={lang}>
  <head>
    <script type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "lvhhjn5lfn");
  </script>
    <!-- LXGW WenKai is now self-hosted as one atomic subset file per weight (see index.css @font-face);
         preload the body weight so Chinese paints fast. -->
    <link rel="preload" as="font" type="font/woff2" href="/fonts/lxgwwenkai-regular.woff2" crossorigin />
    <link rel="stylesheet" href="https://fontsapi.zeoseven.com/442/main/result.css" />
    <!-- refined Latin face: crisp, even weight for English/digits; CJK falls through to WenKai (latin-subsetted) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource-variable/inter@5/index.css" />
    <link rel="sitemap" href="/sitemap-index.xml"/>
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      charset="utf-8"
      title={title}
      titleTemplate={titleTemplate}
      description={desc}
      extend={{
        link: [{ rel: 'icon', href: '/favicon.jpg', type: 'image/jpeg' }],
        meta: [
          { name: "twitter:image:src", content: optimizedImage },
          { name: "twitter:image:alt", content: desc },
          { name: "twitter:creator", content: header.twitter },
          { name: "twitter:site", content: header.twitter },
          { name: "twitter:card", content: "summary_large_image" },
          { name: "twitter:title", content: title },
          { name: "twitter:description", content: desc },
        ],
      }}
      openGraph={{
        basic: {
          title: title,
          type: article ? "article" : "website",
          image: optimizedImage,
          url: pageUrl,
        },
        optional: {
          siteName: themeConfig.title,
          description: desc,
          locale: ogLocale,
        },
        ...(article ? {
          article: {
            publishedTime: article.pubDate.toISOString(),
            modifiedTime: (article.updatedDate ?? article.pubDate).toISOString(),
            authors: [themeConfig.author],
            section: article.categories?.[0],
            tags: article.categories,
          },
        } : {}),
      }}
    />

    {alternates?.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}
    <script type="application/ld+json" is:inline set:html={jsonLd} />

    <script type="text/partytown" src="https://www.googletagmanager.com/gtag/js?id=G-27FYWKG4SY"></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-27FYWKG4SY');
    </script>
    <meta name="baidu-site-verification" content="codeva-vs6hGikUak" />
  </head>
  <body>
    <div un-max-lg="animate-fadein-down" un-lg="flex flex-row-reverse justify-between gap-4 px-8 mx-auto max-w-6xl" class="container contain-layout m-a">
      <div un-lg="sticky top-0 h-screen py-20 animate-fadein-left gap-8" un-lg:flex="~ col justify-between items-start gap-4" class="p-7.5">
        <Header />
        <Footer class="max-lg:hidden" />
      </div>
      <main un-lg="py-20 min-w-xl animate-fadein-down" class="p-7.5">
        <slot />
      </main>
      <Footer class="lg:hidden p-7.5" />
    </div>
  </body>
</html>
